<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SIDEA.Client.ViewModels"
        xmlns:webview="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
        x:Class="SIDEA.Client.Views.KnowledgeWindow"
        x:DataType="vm:KnowledgeViewModel"
        Title="Agentic Graph RAG 知识库管理"
        RequestedThemeVariant="Default"
        Background="{DynamicResource SemiColorBackground0}"
        Width="1050" Height="720"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:KnowledgeViewModel/>
    </Window.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SemiColorBackground1}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="32" Height="32" CornerRadius="8" Background="#B070FF">
                        <TextBlock Text="KB" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Agentic Graph RAG 工业知识库控制中心" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SemiColorPrimary}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main 5 Tabs -->
        <TabControl Grid.Row="1" Margin="16" Background="Transparent">
            <!-- Tab 1: Document Library -->
            <TabItem Header="文档库" FontSize="15">
                <Grid RowDefinitions="Auto,Auto,*" Margin="0,16,0,0">
                    <Border Grid.Row="0" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource SemiColorBackground1}" Padding="32" Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center" Spacing="10">
                            <PathIcon Data="M11 20H6C3.23858 20 1 17.7614 1 15C1 12.5539 2.75338 10.5186 5.06835 10.0818C5.5492 6.6433 8.46197 4 12 4C15.0298 4 17.6186 5.9255 18.6291 8.61817C21.107 8.95079 23 11.087 23 13.6667C23 16.6122 20.6122 19 17.6667 19H16M14 14L11 11L8 14M11 11V20" Width="32" Height="32" Foreground="#54A9FF" HorizontalAlignment="Center"/>
                            <TextBlock Text="点击或拖拽文件到此处上传至知识库" Foreground="{DynamicResource SemiColorText0}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="支持 PDF, DOCX, Excel 以及常见日志格式。后台会自动拆分切片并建立向量索引。" Foreground="{DynamicResource SemiColorText2}" FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                        <TextBlock Grid.Column="0" Text="已入库文档总览" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText1}"/>
                        <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshDocumentsCommand}" Classes="Tertiary" Padding="12,6"/>
                    </Grid>
                    
                    <DataGrid Grid.Row="2" ItemsSource="{Binding Documents}" x:CompileBindings="False" AutoGenerateColumns="False" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="8" RowHeight="44">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="文件名" Width="*" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="类型" Width="100" Binding="{Binding FileType}"/>
                            <DataGridTextColumn Header="大小 (KB)" Width="110" Binding="{Binding SizeKB}"/>
                            <DataGridTextColumn Header="向量块" Width="100" Binding="{Binding VectorChunks}"/>
                            <DataGridTextColumn Header="状态" Width="110" Binding="{Binding Status}"/>
                            <DataGridTextColumn Header="上传时间" Width="160" Binding="{Binding UploadTime}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Vector Embeddings & Slices -->
            <TabItem Header="向量与切片明细" FontSize="15">
                <Grid RowDefinitions="Auto,*" Margin="0,16,0,0">
                    <Border Grid.Row="0" Margin="0,0,0,16" Padding="16" Background="{DynamicResource SemiColorBackground1}" CornerRadius="8" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding VectorTestQuery}" PlaceholderText="输入测试句子以进行向量相似度检索验证 (如: 电机过热处理...)" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button Grid.Column="1" Content="相似度检索测试" Command="{Binding SearchVectorsCommand}" Classes="Solid Primary" Padding="16,8"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Vectors}" x:CompileBindings="False" AutoGenerateColumns="False" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="8" RowHeight="48">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="向量编号" Width="120" Binding="{Binding VectorId}"/>
                            <DataGridTextColumn Header="切片文本内容" Width="*" Binding="{Binding TextSnippet}"/>
                            <DataGridTextColumn Header="维度规格" Width="130" Binding="{Binding VectorDimension}"/>
                            <DataGridTextColumn Header="相似度得分" Width="120" Binding="{Binding SimilarityScore, StringFormat='{}{0:F2}'}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 3: Graph RAG Knowledge Topology Canvas -->
            <TabItem Header="Graph RAG 拓扑关联图谱" FontSize="15">
                <Grid Margin="0,16,0,0">
                    <Border CornerRadius="8" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" ClipToBounds="True">
                        <NativeWebView Name="GraphRagWebView" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- Tab 4: Industrial Experience Audit -->
            <TabItem Header="经验沉淀审核" FontSize="15">
                <Grid RowDefinitions="Auto,*" Margin="0,16,0,0">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                        <TextBlock Grid.Column="0" Text="待审核的工控排查经验 (Human-in-the-Loop)" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText1}"/>
                        <Button Grid.Column="1" Content="刷新" Command="{Binding RefreshExperiencesCommand}" Classes="Tertiary" Padding="12,6"/>
                    </Grid>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Experiences}" x:CompileBindings="False" AutoGenerateColumns="False" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="8" RowHeight="56">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="排查上下文" Width="2*" Binding="{Binding Context}"/>
                            <DataGridTextColumn Header="提取经验规则" Width="2*" Binding="{Binding Rule}"/>
                            <DataGridTextColumn Header="状态" Width="100" Binding="{Binding Status}"/>
                            <DataGridTemplateColumn Header="操作审核" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Content="确认入库" Command="{Binding $parent[Window].DataContext.ApproveExperienceCommand}" CommandParameter="{Binding}" Classes="Solid Primary" Padding="10,4"/>
                                            <Button Content="拒绝" Command="{Binding $parent[Window].DataContext.RejectExperienceCommand}" CommandParameter="{Binding}" Classes="Secondary" Padding="10,4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab 5: Auto-Approval Prompt Rules -->
            <TabItem Header="自动审核 Prompt 规则" FontSize="15">
                <Border Margin="0,16,0,0" Padding="24" Background="{DynamicResource SemiColorBackground1}" CornerRadius="8" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <TextBlock Text="AI 自动审查 Prompt 规则配置" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}"/>
                        <TextBlock Text="设置 Agent 后台自主评估对话并决定是否直接入库知识库的 System Prompt 标准:" Foreground="{DynamicResource SemiColorText2}" FontSize="13"/>
                        <TextBox Text="{Binding AutoRulePrompt}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="180" FontSize="14"/>
                        <Button Content="保存审查规则" Command="{Binding SaveAutoRulesCommand}" Classes="Solid Primary" HorizontalAlignment="Left" Padding="20,10" CornerRadius="6"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
