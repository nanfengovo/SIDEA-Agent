<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SIDEA.Client.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:webview="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
        xmlns:converters="using:SIDEA.Client.Converters"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="SIDEA.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SIDEA Agent - C# Avalonia"
        Background="{DynamicResource SemiColorBackground0}"
        Width="1200" Height="800">

    <Window.Resources>
        <converters:RoleToBackgroundConverter x:Key="RoleToBackgroundConverter"/>
        <converters:RoleToAlignmentConverter x:Key="RoleToAlignmentConverter"/>
        <converters:IconTypeToGeometryConverter x:Key="IconTypeToGeometryConverter"/>
        
        <!-- SVG Icons for DAG -->
        <StreamGeometry x:Key="UserIcon">M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z</StreamGeometry>
        <StreamGeometry x:Key="KeyIcon">M7,14A2,2 0 0,1 5,12A2,2 0 0,1 7,10A2,2 0 0,1 9,12A2,2 0 0,1 7,14M12.65,10C11.83,7.67 9.61,6 7,6A6,6 0 0,0 1,12A6,6 0 0,0 7,18C9.61,18 11.83,16.33 12.65,14H17V18H21V14H23V10H12.65Z</StreamGeometry>
        <StreamGeometry x:Key="BotIcon">M20,9V15H18V19A2,2 0 0,1 16,21H8A2,2 0 0,1 6,19V15H4V9H6V7A2,2 0 0,1 8,5H16A2,2 0 0,1 18,7V9H20M8,19H16V7H8V19M9,9H11V11H9V9M13,9H15V11H13V9Z</StreamGeometry>
        <StreamGeometry x:Key="PlayIcon">M8,5.14V19.14L19,12.14L8,5.14Z</StreamGeometry>
        <StreamGeometry x:Key="CheckIcon">M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41-1.41z</StreamGeometry>
        
        <!-- SVG Icons -->
        <StreamGeometry x:Key="SettingsIcon">M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z</StreamGeometry>
        <StreamGeometry x:Key="PaperclipIcon">M16.5,6v11.5c0,2.21-1.79,4-4,4s-4-1.79-4-4V5c0-1.38,1.12-2.5,2.5-2.5s2.5,1.12,2.5,2.5v10.5c0,0.55-0.45,1-1,1 s-1-0.45-1-1V6H10v9.5c0,1.38,1.12,2.5,2.5,2.5s2.5-1.12,2.5-2.5V5c0-2.21-1.79-4-4-4S7,2.79,7,5v12.5c0,3.04,2.46,5.5,5.5,5.5 s5.5-2.46,5.5-5.5V6H16.5z</StreamGeometry>
        <StreamGeometry x:Key="SendIcon">M2.01,21L23,12L2.01,3L2,10l15,2l-15,2L2.01,21z</StreamGeometry>
        <StreamGeometry x:Key="TraceIcon">M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,20c-4.41,0-8-3.59-8-8s3.59-8,8-8s8,3.59,8,8 S16.41,20,12,20z M11,7h2v6h-2V7z M11,15h2v2h-2V15z</StreamGeometry>
        <StreamGeometry x:Key="ChatIcon">M20,2H4C2.9,2,2,2.9,2,4v18l4-4h14c1.1,0,2-0.9,2-2V4C22,2.9,21.1,2,20,2z</StreamGeometry>
        <StreamGeometry x:Key="TrashIcon">M6,19c0,1.1,0.9,2,2,2h8c1.1,0,2-0.9,2-2V7H6V19z M19,4h-3.5l-1-1h-5l-1,1H5v2h14V4z</StreamGeometry>
        <StreamGeometry x:Key="PlusIcon">M19,13h-6v6h-2v-6H5v-2h6V5h2v6h6V13z</StreamGeometry>
        <StreamGeometry x:Key="SidebarIcon">M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z</StreamGeometry>
        <StreamGeometry x:Key="ThemeIcon">M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z</StreamGeometry>
        <StreamGeometry x:Key="GlobeIcon">M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95c-.32-1.25-.78-2.45-1.38-3.56 1.84.63 3.37 1.91 4.33 3.56zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2 0 .68.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56-1.84-.63-3.37-1.9-4.33-3.56zm2.95-8H5.08c.96-1.66 2.49-2.93 4.33-3.56C8.81 5.55 8.35 6.75 8.03 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2 0-.68.07-1.34.16-2h4.68c.09.66.16 1.32.16 2 0 .68-.07 1.34-.16 2zm1.25 3.56c.6-1.11 1.06-2.31 1.38-3.56h2.95c-.96 1.65-2.49 2.93-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2 0-.68-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z</StreamGeometry>
    </Window.Resources>

    <Window.Styles>
        <!-- Removed ineffective TextBox styles, moving to inline TextBox.Styles for higher specificity -->
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="64,*">
        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="{DynamicResource SemiColorBackground0}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0,0,1" Padding="24,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                    <Button Command="{Binding ToggleSidebarCommand}" Classes="Tertiary" Width="40" Height="40" CornerRadius="20">
                        <PathIcon Data="{StaticResource SidebarIcon}" Width="20" Height="20" Foreground="{DynamicResource SemiColorText1}"/>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="12" Background="{DynamicResource SemiColorPrimary}" Margin="0,0,12,0">
                            <TextBlock Text="S" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="SIDEA Agent" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                            <TextBlock Text="{DynamicResource StrModels}" Foreground="{DynamicResource SemiColorText2}" FontSize="13" VerticalAlignment="Center" />
                            <ComboBox Width="220" ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" CornerRadius="18" Height="34" Padding="12,0" Background="{DynamicResource SemiColorBackground1}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="13"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                            <TextBlock Text="角色" Foreground="{DynamicResource SemiColorText2}" FontSize="13" VerticalAlignment="Center" />
                            <ComboBox Width="180" ItemsSource="{Binding Skills}" SelectedItem="{Binding SelectedSkill}" CornerRadius="18" Height="34" Padding="12,0" Background="{DynamicResource SemiColorBackground1}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontSize="13"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <Button Command="{Binding OpenDashboardCommand}" Classes="Secondary" CornerRadius="16" Padding="10,5" ToolTip.Tip="数字孪生大屏">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="📊" FontSize="13"/>
                                <TextBlock Text="{DynamicResource StrDashboard}" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding OpenKnowledgeBaseCommand}" Classes="Secondary" CornerRadius="16" Padding="10,5" ToolTip.Tip="知识库控制中心">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="🧠" FontSize="13"/>
                                <TextBlock Text="{DynamicResource StrKnowledgeBase}" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding OpenSystemLogsCommand}" Classes="Secondary" CornerRadius="16" Padding="10,5" ToolTip.Tip="系统操作与规则日志">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="⚡" FontSize="13"/>
                                <TextBlock Text="系统日志" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Button Command="{Binding ChangeThemeCommand}" Classes="Tertiary" Width="36" Height="36" CornerRadius="18" ToolTip.Tip="Toggle Theme">
                        <PathIcon Data="{StaticResource ThemeIcon}" Width="18" Height="18" Foreground="{DynamicResource SemiColorText1}"/>
                    </Button>

                    <Button Command="{Binding ChangeLanguageCommand}" Classes="Tertiary" Width="36" Height="36" CornerRadius="18" ToolTip.Tip="Switch Language">
                        <PathIcon Data="{StaticResource GlobeIcon}" Width="18" Height="18" Foreground="{DynamicResource SemiColorText1}"/>
                    </Button>

                    <Button Width="36" Height="36" CornerRadius="18" Classes="Tertiary" Command="{Binding OpenAdminCommand}" ToolTip.Tip="管理后台">
                        <PathIcon Data="{StaticResource SettingsIcon}" Width="18" Height="18" Foreground="{DynamicResource SemiColorText1}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace (SplitView for Sidebar) -->
        <SplitView Grid.Row="1" IsPaneOpen="{Binding IsSidebarOpen}" DisplayMode="Inline" OpenPaneLength="280" PaneBackground="{DynamicResource SemiColorBackground1}" Background="{DynamicResource SemiColorBackground0}">
            <SplitView.Pane>
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Padding="20">
                        <Button Command="{Binding NewSessionCommand}" HorizontalAlignment="Stretch" Classes="Secondary" CornerRadius="12" Padding="0,12">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <PathIcon Data="{StaticResource PlusIcon}" Width="16" Height="16" Foreground="{DynamicResource SemiColorText1}"/>
                                <TextBlock Text="{DynamicResource StrNewSession}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource SemiColorText1}"/>
                            </StackPanel>
                        </Button>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" Padding="12,0">
                        <ItemsControl ItemsSource="{Binding ChatSessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[Window].DataContext.SelectSessionCommand}" CommandParameter="{Binding SessionId}" 
                                            HorizontalAlignment="Stretch" Classes="Tertiary" CornerRadius="10" Margin="0,0,0,4" Padding="10,8"
                                            Background="Transparent" BorderThickness="0">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <PathIcon Grid.Column="0" Data="{StaticResource ChatIcon}" Width="14" Height="14" Foreground="{DynamicResource SemiColorText2}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" ToolTip.Tip="{Binding Title}" Foreground="{DynamicResource SemiColorText1}" TextTrimming="CharacterEllipsis" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <Button Grid.Column="2" Classes="Tertiary" Command="{Binding $parent[Window].DataContext.DeleteSessionCommand}" CommandParameter="{Binding SessionId}" Padding="4" CornerRadius="6" Width="24" Height="24" ToolTip.Tip="删除会话" VerticalAlignment="Center">
                                                <PathIcon Data="{StaticResource TrashIcon}" Width="12" Height="12" Foreground="{DynamicResource SemiColorDanger}"/>
                                            </Button>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </SplitView.Pane>
            
            <SplitView.Content>
                <Grid ColumnDefinitions="*,340">
                    <!-- Chat & Input -->
                    <Grid Grid.Column="0" RowDefinitions="*,Auto">
                        <NativeWebView Name="ChatWebView" Grid.Row="0" Margin="24,24,24,0" />
                        
                        <!-- Soft, Elegant Input Box -->
                        <Border Grid.Row="1" Margin="40,20,40,30" CornerRadius="24" Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource SemiColorBorder}" Padding="20,16">
                            <Grid RowDefinitions="Auto,Auto,Auto">
                                <!-- Reply Box -->
                                <Border Grid.Row="0" Margin="0,0,0,8" Padding="12,8" Background="{DynamicResource SemiColorBackground1}" CornerRadius="8" IsVisible="{Binding ReplyingToMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding ReplyingToMessage}" Foreground="{DynamicResource SemiColorText2}" FontSize="13" TextTrimming="CharacterEllipsis" MaxLines="2" TextWrapping="Wrap"/>
                                        <Button Grid.Column="1" Command="{Binding ClearReplyCommand}" Classes="Tertiary" Padding="4" Margin="8,0,0,0" VerticalAlignment="Top">
                                            <PathIcon Data="{StaticResource PlusIcon}" Width="12" Height="12" Foreground="{DynamicResource SemiColorText2}" RenderTransform="rotate(45deg)"/>
                                        </Button>
                                    </Grid>
                                </Border>
                                
                                <TextBox Grid.Row="1" Text="{Binding InputText}" 
                                         PlaceholderText="{DynamicResource StrInputPlaceholder}" 
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0" MinHeight="44" MaxHeight="200"
                                         FontSize="16"
                                         KeyDown="OnInputKeyDown"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True">
                                    <TextBox.Styles>
                                        <Style Selector="TextBox /template/ Border">
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                        <Style Selector="TextBox:pointerover /template/ Border">
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                        <Style Selector="TextBox:focus /template/ Border">
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                        <Style Selector="TextBox:focus-within /template/ Border">
                                            <Setter Property="Background" Value="Transparent" />
                                        </Style>
                                    </TextBox.Styles>
                                </TextBox>
                                
                                <!-- Action Bar -->
                                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,16,0,0">
                                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                                        <Button Classes="Tertiary" Command="{Binding UploadAttachmentCommand}" Padding="8,4" CornerRadius="12" Margin="0,0,8,6">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <PathIcon Data="{StaticResource PaperclipIcon}" Width="14" Height="14" Foreground="{DynamicResource SemiColorText2}"/>
                                                <TextBlock Text="{DynamicResource StrAddAttachment}" FontSize="13" Foreground="{DynamicResource SemiColorText2}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,6">
                                            <ToggleSwitch IsChecked="{Binding UseKnowledge}" Classes="Solid" />
                                            <Button Classes="Tertiary" Command="{Binding OpenKnowledgeBaseCommand}" Padding="6,4" CornerRadius="12" Margin="4,0,0,0">
                                                <TextBlock Text="{DynamicResource StrKnowledgeBase}" FontSize="13" Foreground="{DynamicResource SemiColorText2}" VerticalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>

                                        <!-- Toolbar Dropdowns: Thinking Depth, Context Length, Execution Mode, Permission Mode -->
                                        <ComboBox ItemsSource="{Binding ThinkingDepths}" SelectedItem="{Binding ThinkingDepthDisplay}" Width="105" Height="30" FontSize="12" CornerRadius="14" Background="{DynamicResource SemiColorBackground1}" BorderThickness="0" Padding="8,0" Margin="0,0,6,6"/>
                                        <ComboBox ItemsSource="{Binding ContextLengths}" SelectedItem="{Binding ContextLengthDisplay}" Width="105" Height="30" FontSize="12" CornerRadius="14" Background="{DynamicResource SemiColorBackground1}" BorderThickness="0" Padding="8,0" Margin="0,0,6,6"/>
                                        <ComboBox ItemsSource="{Binding ExecutionModes}" SelectedItem="{Binding ExecutionModeDisplay}" Width="105" Height="30" FontSize="12" CornerRadius="14" Background="{DynamicResource SemiColorBackground1}" BorderThickness="0" Padding="8,0" Margin="0,0,6,6"/>
                                        <ComboBox ItemsSource="{Binding PermissionModes}" SelectedItem="{Binding PermissionModeDisplay}" Width="145" Height="30" FontSize="12" CornerRadius="14" Background="{DynamicResource SemiColorBackground1}" BorderThickness="0" Padding="8,0" Margin="0,0,6,6"/>
                                    </WrapPanel>

                                    <Button Grid.Column="1" Command="{Binding SendMessageCommand}" Width="40" Height="40" CornerRadius="20" Classes="Solid Primary" VerticalAlignment="Bottom" Margin="0,0,0,8">
                                        <PathIcon Data="{StaticResource SendIcon}" Width="18" Height="18" Foreground="White" Margin="-2,0,0,0"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Trace Panel -->
                    <Grid Grid.Column="1" RowDefinitions="Auto,*" Background="{DynamicResource SemiColorBackground0}" Margin="1,0,0,0">
                        <Border Grid.Row="0" Padding="24,20" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource TraceIcon}" Width="18" Height="18" Foreground="{DynamicResource SemiColorPrimary}" VerticalAlignment="Center"/>
                                <TextBlock Text="执行链路追踪" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1,0,0,0">
                            <NativeWebView Name="TraceWebView" Margin="0" />
                        </Border>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>

        <!-- Approval Dialog Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="#80000000" IsVisible="{Binding IsApprovalDialogVisible}" ZIndex="999">
            <Border Background="{DynamicResource SemiColorBackground0}" CornerRadius="16" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32">
                <StackPanel Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <PathIcon Data="{StaticResource KeyIcon}" Width="24" Height="24" Foreground="{DynamicResource SemiColorWarning}"/>
                        <TextBlock Text="请求操作授权" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Text="{Binding PendingApprovalMessage}" TextWrapping="Wrap" Foreground="{DynamicResource SemiColorText1}" FontSize="15" LineHeight="24" />
                    
                    <Grid ColumnDefinitions="*,16,*" Margin="0,16,0,0">
                        <Button Grid.Column="0" Command="{Binding RejectToolCommand}" Classes="Tertiary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="12" Padding="0,12">
                            <TextBlock Text="拒绝 (Reject)" FontWeight="SemiBold"/>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding ApproveToolCommand}" Classes="Solid Warning" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="12" Padding="0,12">
                            <TextBlock Text="授权允许 (Approve)" FontWeight="SemiBold" Foreground="White"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
