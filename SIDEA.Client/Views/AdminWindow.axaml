<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SIDEA.Client.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="SIDEA.Client.Views.AdminWindow"
        x:DataType="vm:AdminViewModel"
        Title="Admin Console"
        RequestedThemeVariant="Dark"
        Background="#0a0a0f"
        Width="1000" Height="700">

    <Window.DataContext>
        <vm:AdminViewModel/>
    </Window.DataContext>

    <Grid ColumnDefinitions="250,*">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#12121a" BorderBrush="#1a1a2e" BorderThickness="0,0,1,0">
            <StackPanel>
                <Border Height="60" BorderBrush="#1a1a2e" BorderThickness="0,0,0,1">
                    <TextBlock Text="Admin Console" FontSize="18" FontWeight="Bold" Foreground="#00f2fe" VerticalAlignment="Center" Margin="20,0"/>
                </Border>
                <ListBox Background="Transparent" SelectionChanged="OnTabSelectionChanged" SelectedIndex="0" Margin="10">
                    <ListBoxItem Content="全局设置 (Config)" Foreground="#e2e2e2" Padding="15,10" CornerRadius="8"/>
                    <ListBoxItem Content="技能 &amp; 提示词 (Skills)" Foreground="#e2e2e2" Padding="15,10" CornerRadius="8"/>
                    <ListBoxItem Content="工具总览 (Tools)" Foreground="#e2e2e2" Padding="15,10" CornerRadius="8"/>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Border Grid.Column="1" Padding="20">
            <Grid>
                <!-- Config Tab -->
                <Grid x:Name="ConfigTab" IsVisible="True" RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="全局设置 (Sys Config)" FontSize="24" FontWeight="Bold" Foreground="#fff"/>
                        <Button Content="+ Add Config" HorizontalAlignment="Right" Background="#00f2fe" Foreground="Black" FontWeight="Bold" Click="OnAddConfigClick"/>
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Configs}" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConfigItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Margin="0,5">
                                        <TextBlock Text="{Binding ConfigKey}" FontWeight="Bold" Foreground="#00f2fe"/>
                                        <TextBlock Text="{Binding ConfigValue}" Foreground="#e2e2e2" Margin="0,2"/>
                                        <TextBlock Text="{Binding Description}" Foreground="#8892b0" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10" Margin="10,0,0,0">
                                        <Button Content="Edit" Command="{Binding $parent[Window].((vm:AdminViewModel)DataContext).EditConfigCommand}" CommandParameter="{Binding}" Background="#2a2a3e" Foreground="White" Padding="10,5"/>
                                        <Button Content="Delete" Command="{Binding $parent[Window].((vm:AdminViewModel)DataContext).DeleteConfigCommand}" CommandParameter="{Binding}" Background="#3e1a1a" Foreground="#ff4a4a" Padding="10,5"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Skills Tab -->
                <Grid x:Name="SkillsTab" IsVisible="False" RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="技能 &amp; 提示词 (Skills &amp; Prompts)" FontSize="24" FontWeight="Bold" Foreground="#fff"/>
                        <Button Content="+ Add Skill" HorizontalAlignment="Right" Background="#b300ff" Foreground="White" FontWeight="Bold" Click="OnAddSkillClick"/>
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Skills}" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SkillConfigItem">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Margin="0,5">
                                        <TextBlock Text="{Binding SkillName}" FontWeight="Bold" Foreground="#b300ff"/>
                                        <TextBlock Text="{Binding SkillId}" Foreground="#00f2fe" Margin="0,2"/>
                                        <TextBlock Text="{Binding Description}" Foreground="#e2e2e2" Margin="0,2"/>
                                        <TextBlock Text="{Binding TemplatePath}" Foreground="#8892b0" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10" Margin="10,0,0,0">
                                        <Button Content="Edit" Command="{Binding $parent[Window].((vm:AdminViewModel)DataContext).EditSkillCommand}" CommandParameter="{Binding}" Background="#2a2a3e" Foreground="White" Padding="10,5"/>
                                        <Button Content="Delete" Command="{Binding $parent[Window].((vm:AdminViewModel)DataContext).DeleteSkillCommand}" CommandParameter="{Binding}" Background="#3e1a1a" Foreground="#ff4a4a" Padding="10,5"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Tools Tab -->
                <Grid x:Name="ToolsTab" IsVisible="False" RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="工具总览 (Tools Hub)" FontSize="24" FontWeight="Bold" Foreground="#fff" Margin="0,0,0,20"/>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Tools}" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ToolItem">
                                <StackPanel Margin="0,5">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#4facfe"/>
                                    <TextBlock Text="{Binding Key}" Foreground="#00f2fe" Margin="0,2"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#8892b0" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
