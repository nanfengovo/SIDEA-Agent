<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SIDEA.Client.ViewModels"
        x:Class="SIDEA.Client.Views.SkillEditWindow"
        Title="Edit Skill" Width="500" Height="450"
        WindowStartupLocation="CenterOwner"
        Background="#12121a">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Skill ID" Foreground="White" FontWeight="Bold"/>
        <TextBox x:Name="IdBox" Text="" IsEnabled="False" Background="#1a1a2e" Foreground="White"/>
        
        <TextBlock Text="Skill Name" Foreground="White" FontWeight="Bold"/>
        <TextBox x:Name="NameBox" Text="" Background="#1a1a2e" Foreground="White"/>
        
        <TextBlock Text="Description" Foreground="White" FontWeight="Bold"/>
        <TextBox x:Name="DescBox" Text="" Background="#1a1a2e" Foreground="White"/>
        
        <TextBlock Text="Template Path" Foreground="White" FontWeight="Bold"/>
        <TextBox x:Name="PathBox" Text="" Background="#1a1a2e" Foreground="White"/>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="Cancel" Click="OnCancelClick" Background="#2a2a3e" Foreground="White"/>
            <Button Content="Save" Click="OnSaveClick" Background="#b300ff" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </StackPanel>
</Window>
